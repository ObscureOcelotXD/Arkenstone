# Optional: only if you are NOT using Infisical for secrets.
# This project uses Infisical (see docs/INFISICAL.md). With Infisical, leave .env empty or delete it.
# If you don't use Infisical, copy this file to .env and fill in the values below.

# --- Sepolia deploy ---
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
PRIVATE_KEY=your_wallet_private_key_without_0x_prefix

# --- Local Graph Node (docker compose) ---
GRAPH_POSTGRES_PASSWORD=your_secure_password

# --- Admin app (Vite) ---
VITE_RPC_URL=http://127.0.0.1:8545
# VITE_STAKING_ADDRESS=0x...   # set by sync-admin-env after deploy:local
# VITE_SUBGRAPH_URL=http://localhost:5174/subgraphs/name/arkenstone/arkenstone
