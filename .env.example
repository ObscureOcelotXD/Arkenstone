# Single .env for the project. Copy to .env in this directory (repo root) and fill in.
# Used by: Hardhat, deploy scripts, Docker Compose, and the admin app (Vite reads from here).

# --- Sepolia deploy ---
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
PRIVATE_KEY=your_wallet_private_key_without_0x_prefix

# --- Local Graph Node (docker compose) ---
# Required for `docker compose up`. No default.
GRAPH_POSTGRES_PASSWORD=your_secure_password

# --- Admin app (Vite). Optional; sync-admin-env / deploy:local can set these from deployment. ---
VITE_RPC_URL=http://127.0.0.1:8545
# VITE_STAKING_ADDRESS=0x...   # set by sync-admin-env after deploy:local
# VITE_SUBGRAPH_URL=http://localhost:5174/subgraphs/name/arkenstone/arkenstone   # local proxy; or your hosted subgraph URL
