# RPC URL for the chain (e.g. http://127.0.0.1:8545 for local Hardhat)
VITE_RPC_URL=http://127.0.0.1:8545

# Staking contract address (optional if using config/contracts.js defaults)
# VITE_STAKING_ADDRESS=0x...

# The Graph subgraph URL (optional). Use a relative path so the admin dev server proxies to Graph Node (no CORS):
# VITE_SUBGRAPH_URL=/subgraphs/name/arkenstone/arkenstone
# For hosted: VITE_SUBGRAPH_URL=https://api.thegraph.com/subgraphs/name/your-org/arkenstone
